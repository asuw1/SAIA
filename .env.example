# Database
DATABASE_URL=postgresql+asyncpg://saia:saia_password@localhost:5432/saia_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saia_db
DB_USER=saia
DB_PASSWORD=change-this-in-production

# JWT
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

# LLM
LLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=llama-3.1-70b
LLM_MOCK_MODE=true

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768

# Rate Limiting
INGEST_RATE_LIMIT=60/minute

# App
APP_NAME=SAIA
APP_VERSION=4.0.0
DEBUG=false
